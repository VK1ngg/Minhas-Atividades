lista = input("Digite, na mesma linha, as três notas de um aluno: ").split()
n1, n2, n3 = float(lista[0]), float(lista[1]), float(lista[2])
if (n1+n2+n3)/3 >= 7:
    print("O aluno está aprovado.")
elif (n1+n2+n3)/3 < 5:
    print("O aluno está reprovado.")
else:
    print("O aluno terá que fazer uma prova final.")
