def fibonacci(n):
    if n == 1:
        return 1
    elif n <= 0:
        return 0
    if n >= 0:
        return fibonacci(n-1) + fibonacci(n-2)

x = int(input("Digite o termo da sequência de fibonacci que deseja: "))
while x < 0:
    print("Não existem termos negativos na sequência.")
    x = int(input("Digite o termo da sequência de fibonacci que deseja: "))
print("O termo é", fibonacci(x))
