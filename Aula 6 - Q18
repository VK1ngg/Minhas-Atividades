def soma_ate_n(n):
    if n == 0:
        return (n)
    else:
        n = n + soma_ate_n(n-1)
        return (n)
        
N = int(input("Digite o número que deseja somar por todos menores que ele: "))
while N <= 0:
    print("Não seria possível com um número negativo ou de zero.")
    N = int(input("Digite o número que deseja somar por todos menores que ele: "))
print("O resultado é", soma_ate_n(N))
