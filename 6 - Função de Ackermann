def ack(m, n):
    if m == 0:
        return (n + 1)
    elif n == 0:
        return(ack(m - 1, 1))
    else:
        return(ack(m-1, ack(m, n - 1)))

print("Este programa realiza a função de Ackermann.")
print("Os dois valores devem ser números inteiros positivos.")

