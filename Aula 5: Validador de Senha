def validador_senha(senha):
    j = 0
    for i in senha:
        if (i == '1' or i == '2' or i == '3' or i == '4'
        or i == '5' or i == '6'
        or i == '7' or i == '8'
        or i == '9' or i == '0'):
            j = j+1
    if len(senha) >= 8 and j > 0:
        return True
    else:
        return False

print("A senha será validada se tiver 8 ou mais caracteres e ao menos um número.")
x = input("Digite a senha que deseja validar: ")
print(validador_senha(x))
